        "class VocabTokenizer:\n",
        "    \"\"\"keras Tokenizer 대체 — 어떤 TF/Keras 버전에서도 동작\"\"\"\n",
        "\n",
        "    def __init__(self, oov_token=\"<unk>\"):\n",
        "        self.oov_token = oov_token\n",
        "        self.word_index = {}\n",
