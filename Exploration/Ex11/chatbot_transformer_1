        "# --- Transformer (Embedding 공유!) ---\n",
        "class Transformer(tf.keras.Model):\n",
        "    def __init__(self, n_layers, d_model, n_heads, d_ff, vocab_size,\n",
        "                 pos_len=200, dropout=0.2, shared=True):\n",
        "        super().__init__()\n",
        "        self.d_model = d_model\n",
        "        self.n_layers = n_layers\n",
        "\n",
        "        # 소스/타겟이 같은 언어이므로 Embedding을 공유\n",
        "        self.embedding = tf.keras.layers.Embedding(vocab_size, d_model)\n",
        "        self.pos_encoding = positional_encoding(pos_len, d_model)\n",
        "\n",
        "        self.enc_layers = [EncoderLayer(d_model, n_heads, d_ff, dropout)\n",
        "                           for _ in range(n_layers)]\n",
        "        self.dec_layers = [DecoderLayer(d_model, n_heads, d_ff, dropout)\n",
        "                           for _ in range(n_layers)]\n",
        "\n",
        "        self.enc_dropout = tf.keras.layers.Dropout(dropout)\n",
        "        self.dec_dropout = tf.keras.layers.Dropout(dropout)\n",
        "\n",
        "        self.fc = tf.keras.layers.Dense(vocab_size)\n",
        "        self.shared = shared\n",
        "\n",
        "    def embed(self, x):\n",
        "        seq_len = tf.shape(x)[1]\n",
        "        out = self.embedding(x)\n",
        "        out *= tf.math.sqrt(tf.cast(self.d_model, tf.float32))\n",
        "        out += self.pos_encoding[:, :seq_len, :]\n",
        "        return out\n",
        "\n",
        "    def call(self, enc_in, dec_in, enc_mask, dec_enc_mask, dec_mask, training=False):\n",
        "        # Encoder\n",
        "        enc_out = self.enc_dropout(self.embed(enc_in), training=training)\n",
        "        for layer in self.enc_layers:\n",
        "            enc_out = layer(enc_out, enc_mask, training=training)\n",
        "\n",
        "        # Decoder\n",
        "        dec_out = self.dec_dropout(self.embed(dec_in), training=training)\n",
        "        attn_weights = {}\n",
        "        for i, layer in enumerate(self.dec_layers):\n",
        "            dec_out, w1, w2 = layer(dec_out, enc_out, dec_enc_mask, dec_mask,\n",
        "                                    training=training)\n",
        "            attn_weights[f\"dec_layer{i+1}_self\"] = w1\n",
        "            attn_weights[f\"dec_layer{i+1}_enc\"] = w2\n",
        "\n",
        "        logits = self.fc(dec_out)\n",
        "        return logits, attn_weights"
