        "    def fit_on_corpus(self, corpus):  # corpus: 토큰 리스트의 리스트\n",
        "        counter = Counter(tok for tokens in corpus for tok in tokens)\n",
        "        self.word_index = {self.oov_token: 1}  # 0번은 패딩\n",
        "        for idx, (word, _) in enumerate(counter.most_common(), start=2):\n",
