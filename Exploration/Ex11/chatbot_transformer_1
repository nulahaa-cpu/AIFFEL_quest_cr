        "        pred_id = tf.cast(tf.argmax(predictions[:, -1, :], axis=-1), tf.int32)\n",
        "\n",
        "        if int(pred_id.numpy()[0]) == end_id:\n",
        "            break\n",
        "\n",
        "        dec_input = tf.concat([dec_input, tf.expand_dims(pred_id, 0)], axis=-1)\n",
        "\n",
        "    return list(dec_input.numpy()[0][1:])  # <start> 제외\n",
        "\n",
        "\n",
        "def chat(sentence, model, tokenizer):\n",
        "    tokens = mecab.morphs(preprocess_sentence(sentence))\n",
        "    src = tokens_to_padded_seq(tokens, tokenizer, ENC_MAXLEN)\n",
        "    ids = evaluate_ids(src, model, tokenizer)\n",
        "    words = [tokenizer.index_word.get(i, \"<unk>\") for i in ids]\n",
        "    answer = \" \".join(words)\n",
        "    print(f\"Q: {sentence}\")\n",
        "    print(f\"A: {answer} <end>\\n\")\n",
        "    return answer"
