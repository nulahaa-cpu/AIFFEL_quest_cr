        "## Step 2. 데이터 정제\n",
        "\n",
        "`preprocess_sentence()` 구현 조건\n",
        "\n",
        "1. 영문자는 모두 소문자로 변환\n",
        "2. 영문자·한글·숫자·주요 특수문자(`?.!,`)를 제외한 문자는 정규식으로 제거\n",
        "\n",
        "(문장부호 양옆 공백 추가 등은 Mecab 토크나이저가 알아서 처리해 주므로 생략!)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 6,
      "id": "42e12e44",
      "metadata": {
        "lines_to_next_cell": 1,
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "42e12e44",
        "outputId": "7a41b3db-bd59-48b0-f542-279373e96528"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "12시 땡!!!\n",
            "hello world 반가워\n",
            "3박4일 놀러가고 싶다...\n"
          ]
        }
      ],
      "source": [
        "def preprocess_sentence(sentence):\n",
        "    # 1. 소문자 변환 + 양쪽 공백 제거\n",
        "    sentence = str(sentence).lower().strip()\n",
        "\n",
        "    # 2. 한글, 영문자, 숫자, 주요 특수문자(?.!,)만 남기고 제거\n",
        "    sentence = re.sub(r\"[^가-힣a-z0-9?.!,]+\", \" \", sentence)\n",
        "    sentence = re.sub(r\"\\s+\", \" \", sentence).strip()\n",
        "\n",
        "    return sentence\n",
        "\n",
        "\n",
        "# 동작 확인\n",
        "print(preprocess_sentence(\"12시 땡!!!\"))\n",
        "print(preprocess_sentence(\"Hello World~~ 반가워 :)\"))\n",
        "print(preprocess_sentence(\"3박4일  놀러가고 싶다...\"))"
      ]
    },
