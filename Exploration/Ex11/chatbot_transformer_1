        "        tgt_sentence = preprocess_sentence(tgt)\n",
        "\n",
        "        # 2) 토큰화\n",
        "        src_tokens = tokenize_fn(src_sentence)\n",
        "        tgt_tokens = tokenize_fn(tgt_sentence)\n",
        "\n",
        "        # 3) 길이 필터링 (토큰 개수가 max_len 이상이면 제외)\n",
        "        if len(src_tokens) >= max_len or len(tgt_tokens) >= max_len:\n",
        "            continue\n",
        "\n",
        "        # 4) 중복 제거 (소스/타겟 각각 검사, 쌍 단위로 제외)\n",
        "        src_key = \" \".join(src_tokens)\n",
        "        tgt_key = \" \".join(tgt_tokens)\n",
        "        if src_key in seen_src or tgt_key in seen_tgt:\n",
        "            continue\n",
        "        seen_src.add(src_key)\n",
        "        seen_tgt.add(tgt_key)\n",
        "\n",
        "        src_corpus.append(src_tokens)\n",
        "        tgt_corpus.append(tgt_tokens)\n",
