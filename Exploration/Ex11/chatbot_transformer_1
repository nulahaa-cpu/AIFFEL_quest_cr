        "def lexical_sub(tokens, w2v, ratio=0.15):\n",
        "    \"\"\"토큰 리스트에서 일부 단어를 Word2Vec 최유사 단어로 치환.\n",
        "    치환이 한 번도 일어나지 않으면 None을 반환합니다.\"\"\"\n",
        "    new_tokens = []\n",
        "    replaced = False\n",
        "\n",
        "    for tok in tokens:\n",
        "        if random.random() < ratio and tok in w2v:\n",
        "            try:\n",
        "                similar = w2v.most_similar(tok, topn=1)[0][0]\n",
        "                new_tokens.append(similar)\n",
        "                replaced = True\n",
        "            except (KeyError, ValueError):\n",
        "                new_tokens.append(tok)\n",
        "        else:\n",
        "            new_tokens.append(tok)\n",
        "\n",
        "    return new_tokens if replaced else None"
      ]
