        "# --- Loss (패딩 마스킹) ---\n",
        "loss_object = tf.keras.losses.SparseCategoricalCrossentropy(\n",
        "    from_logits=True, reduction=\"none\")\n",
        "\n",
        "def loss_function(real, pred):\n",
        "    mask = tf.math.logical_not(tf.math.equal(real, 0))\n",
        "    loss_ = loss_object(real, pred)\n",
        "    mask = tf.cast(mask, dtype=loss_.dtype)\n",
        "    loss_ *= mask\n",
        "    return tf.reduce_sum(loss_) / tf.reduce_sum(mask)\n",
        "\n",
        "\n",
        "train_loss = tf.keras.metrics.Mean(name=\"train_loss\")\n",
        "train_accuracy = tf.keras.metrics.SparseCategoricalAccuracy(name=\"train_accuracy\")\n",
        "\n",
        "\n",
        "def reset_metric(metric):\n",
        "    # TF 버전에 따라 reset_states / reset_state 이름이 다름\n",
        "    if hasattr(metric, \"reset_states\"):\n",
        "        metric.reset_states()\n",
        "    else:\n",
        "        metric.reset_state()\n",
        "\n",
        "\n",
        "@tf.function\n",
        "def train_step(src, tgt):\n",
        "    tgt_in = tgt[:, :-1]   # <start> ... 마지막 토큰 제외\n",
        "    tgt_out = tgt[:, 1:]   # <start> 제외 ... <end>\n",
        "\n",
        "    enc_mask, dec_enc_mask, dec_mask = generate_masks(src, tgt_in)\n",
        "\n",
        "    with tf.GradientTape() as tape:\n",
        "        predictions, _ = transformer(src, tgt_in, enc_mask, dec_enc_mask, dec_mask,\n",
        "                                     training=True)\n",
        "        loss = loss_function(tgt_out, predictions)\n",
        "\n",
        "    gradients = tape.gradient(loss, transformer.trainable_variables)\n",
        "    optimizer.apply_gradients(zip(gradients, transformer.trainable_variables))\n",
        "\n",
        "    train_loss(loss)\n",
        "    mask = tf.math.logical_not(tf.math.equal(tgt_out, 0))\n",
        "    train_accuracy(tgt_out, predictions, sample_weight=tf.cast(mask, tf.float32))"
