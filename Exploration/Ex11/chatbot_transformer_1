        "from nltk.translate.bleu_score import sentence_bleu, SmoothingFunction\n",
        "\n",
        "def calculate_bleu(model, que_corpus, ans_corpus, tokenizer, n_samples=100,\n",
        "                   verbose_every=20):\n",
        "    \"\"\"que_corpus의 질문으로 답변을 생성하고, ans_corpus를 참조로 BLEU 평균 계산\"\"\"\n",
        "    smoothing = SmoothingFunction().method1\n",
        "    total_bleu = 0.0\n",
        "    n = min(n_samples, len(que_corpus))\n",
        "\n",
        "    for i in range(n):\n",
        "        reference = ans_corpus[i]          # 원본 답변 토큰 (start/end 없음)\n",
        "        src = tokens_to_padded_seq(que_corpus[i], tokenizer, ENC_MAXLEN)\n",
        "        ids = evaluate_ids(src, model, tokenizer)\n",
        "        candidate = [tokenizer.index_word.get(t, \"<unk>\") for t in ids]\n",
        "        if not candidate:\n",
        "            candidate = [\"<unk>\"]\n",
        "\n",
        "        bleu = sentence_bleu([reference], candidate,\n",
        "                             smoothing_function=smoothing)\n",
        "        total_bleu += bleu\n",
        "\n",
        "        if verbose_every and i % verbose_every == 0:\n",
        "            print(f\"[{i}] Q: {' '.join(que_corpus[i])}\")\n",
        "            print(f\"     정답: {' '.join(reference)}\")\n",
        "            print(f\"     생성: {' '.join(candidate)}\")\n",
        "            print(f\"     BLEU: {bleu:.4f}\\n\")\n",
        "\n",
        "    avg_bleu = total_bleu / n\n",
        "    print(f\"===== 평균 BLEU Score ({n} samples): {avg_bleu:.4f} =====\")\n",
        "    return avg_bleu\n",
        "\n",
        "\n",
        "# 원본(Augmentation 이전) 코퍼스에서 샘플링하여 평가\n",
        "bleu_score = calculate_bleu(transformer, que_corpus, ans_corpus, tokenizer,\n",
